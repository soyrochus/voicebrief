#!/bin/sh

# Voicebrief - Converts video / audio conversations to text and subsequently provides a summary into a manageable report.
# © 2024 Iwan van der Kleijn | MIT

set -e

# Prefer running within the uv-managed environment so dependencies are available.
if command -v uv >/dev/null 2>&1; then
	exec uv run -q python -m voicebrief "$@"
fi

# Fallback to a local virtualenv if present
if [ -x "$(dirname "$0")/../.venv/bin/python" ]; then
	exec "$(dirname "$0")/../.venv/bin/python" -m voicebrief "$@"
fi

# Final fallback: system Python
exec python3 -m voicebrief "$@"
